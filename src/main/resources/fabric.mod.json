  "authors": ["vz"],
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": ["com.vz.follow.VzFollowClient"]
  },
  "mixins": [
    "vzfollow.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.0",
    "minecraft": "~1.21.11",
    "fabric-api": "*",
    "java": ">=21"
  }
}
